rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Basic authentication check function
    function isAuthenticated() {
      return request.auth != null;
    }

    // User profiles - users can read and write their own profile
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAuthenticated() && request.auth.uid == userId;
    }

    // Organizations - authenticated users can create, read, and write (for now)
    match /organizations/{orgId} {
      allow read, write: if isAuthenticated();
    }

    // API Keys - authenticated users can manage their organization's keys
    match /apiKeys/{keyId} {
      allow read, write: if isAuthenticated();
    }

    // Logs - authenticated users can write logs
    match /logs/{logId} {
      allow write: if isAuthenticated();
      allow read: if false; // Only backend or admins should read logs
    }
  }
}
